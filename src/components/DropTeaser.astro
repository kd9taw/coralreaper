---
const tiles = [
  {
    badge: 'The Drop',
    title: 'Friday Drops',
    body: 'Limited, numbered frags released weekly once the storefront opens. List members get a 12-hour head start.',
    accent: 'coral',
  },
  {
    badge: 'WYSIWYG',
    title: 'What you see is what ships',
    body: 'Every frag photographed under actinic-only lighting, on a black background. No bait-and-switch stock photos.',
    accent: 'cyan',
  },
  {
    badge: 'Reaper’s Cut',
    title: 'Premium tier',
    body: 'A small line of named, mother-colony pieces. Released only when something earns the title.',
    accent: 'yellow',
  },
];
---

<section class="section drops-teaser">
  <div class="container">
    <p class="eyebrow">What’s coming</p>
    <h2>A small catalog. A short list. No filler.</h2>
    <p class="lede">
      We're building a tight inventory of aquacultured frags worth keeping for years.
      Here’s the shape of it.
    </p>
    <div class="grid">
      {tiles.map((t) => (
        <article class:list={['tile', `accent-${t.accent}`]}>
          <span class="badge">{t.badge}</span>
          <h3>{t.title}</h3>
          <p>{t.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .lede {
    font-size: 1.05rem;
    color: var(--color-bone-dim);
    margin-bottom: var(--space-12);
    max-width: 60ch;
  }

  .grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }

  .tile {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .tile:hover {
    transform: translateY(-2px);
  }

  .accent-coral { border-top: 3px solid var(--color-coral); }
  .accent-cyan { border-top: 3px solid var(--color-cyan); }
  .accent-yellow { border-top: 3px solid var(--color-yellow); }

  .badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    margin-bottom: var(--space-4);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-bone);
  }

  .accent-coral .badge { color: var(--color-coral); }
  .accent-cyan .badge { color: var(--color-cyan); }
  .accent-yellow .badge { color: var(--color-yellow); }

  h3 {
    margin-bottom: var(--space-3);
  }
</style>
