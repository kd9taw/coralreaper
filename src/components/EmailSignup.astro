---
interface Props {
  variant?: 'hero' | 'inline';
  heading?: string;
  description?: string;
}

const {
  variant = 'inline',
  heading = 'Be first when frags drop',
  description = 'Drop alerts, restocks, and a heads-up before anything goes live. No spam, ever.',
} = Astro.props;

// Buttondown is the default. Replace BUTTONDOWN_USERNAME at deploy time
// (env var or just edit this file) once a Buttondown account is live.
const BUTTONDOWN_USERNAME = 'coralreaper';
const action = `https://buttondown.email/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`;
---

<aside class:list={['signup', `signup-${variant}`]}>
  {variant === 'inline' && <p class="eyebrow">Newsletter</p>}
  <h3>{heading}</h3>
  <p class="desc">{description}</p>
  <form
    action={action}
    method="post"
    target="popupwindow"
    onsubmit={`window.open('${action}', 'popupwindow')`}
    class="form"
  >
    <label class="visually-hidden" for="bd-email">Email address</label>
    <input
      id="bd-email"
      name="email"
      type="email"
      required
      autocomplete="email"
      placeholder="you@reef.com"
    />
    <button type="submit" class="btn">Join the list</button>
    <input type="hidden" value="1" name="embed" />
  </form>
  <p class="fineprint">We'll only email when something new drops.</p>
</aside>

<style>
  .signup {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8) var(--space-6);
  }

  @media (min-width: 640px) {
    .signup { padding: var(--space-12) var(--space-8); }
  }

  .signup-hero {
    background: transparent;
    border: 0;
    padding: 0;
  }

  h3 {
    margin-bottom: var(--space-3);
  }

  .desc {
    margin-bottom: var(--space-6);
    color: var(--color-bone-dim);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 540px) {
    .form {
      flex-direction: row;
    }
  }

  input[type='email'] {
    flex: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    color: var(--color-bone);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color 0.15s ease;
  }

  input[type='email']:focus {
    border-color: var(--color-coral);
    outline: none;
  }

  input::placeholder {
    color: var(--color-bone-faint);
  }

  .fineprint {
    margin-top: var(--space-3);
    color: var(--color-bone-faint);
    font-size: 0.8rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
