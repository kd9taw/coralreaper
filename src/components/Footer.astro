---
import { ETSY_SHOP_URL, FACEBOOK_URL } from '../data/etsy';
const year = new Date().getFullYear();
const CONTACT_EMAIL = 'contact@coralreaper.com';
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="col brand-col">
      <img src="/logo.png" alt="Coral Reaper" width="56" height="56" />
      <p class="tagline">Frags I grow. Gear I print.</p>
      <div class="socials">
        <a href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer" aria-label="Coral Reaper on Etsy" class="social etsy">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M9.16 4.18v6.6h3.86c.6 0 .92-.45.92-.93h.65v3.16h-.65c0-.48-.32-.92-.92-.92H9.16v5.46c0 .98.18 1.27 1.42 1.27h3.95c1.55 0 2.31-1.05 3.18-2.97l.6.18-.86 4.55H4.5v-.74c1.65-.4 1.85-.45 1.85-1.83V6.74c0-1.39-.2-1.43-1.85-1.83v-.73h13.9l.18 3.65-.6.07c-.3-1.36-.66-2.4-1.6-2.97-.55-.34-1.4-.45-2.7-.45H9.16z"/>
          </svg>
          <span>Etsy</span>
        </a>
        <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer" aria-label="Coral Reaper on Facebook" class="social fb">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M22 12.07C22 6.51 17.52 2 12 2S2 6.51 2 12.07c0 5.02 3.66 9.18 8.44 9.93v-7.02H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.91h-2.33V22c4.78-.75 8.44-4.91 8.44-9.93z"/>
          </svg>
          <span>Facebook</span>
        </a>
        <a href={`mailto:${CONTACT_EMAIL}`} aria-label="Email Coral Reaper" class="social email">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="m3 7 9 6 9-6"/>
          </svg>
          <span>Email</span>
        </a>
      </div>
    </div>
    <div class="col">
      <h4>Site</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/frags">Browse frags</a></li>
        <li><a href="/shop">Shop accessories</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/drops">Roadmap</a></li>
      </ul>
    </div>
    <div class="col">
      <h4>Buy</h4>
      <ul>
        <li><a href="/frags">Frags · local pickup</a></li>
        <li><a href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer">Gear on Etsy ↗</a></li>
        <li><a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">Facebook DM ↗</a></li>
        <li><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></li>
      </ul>
    </div>
  </div>
  <hr class="divider" />
  <div class="container legal">
    <span>© {year} Coral Reaper. Hand-grown corals, hand-printed gear. USA.</span>
    <span class="legal-right">
      <a href="/privacy">Privacy</a>
    </span>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-24);
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
  }

  .footer-inner {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
    padding-bottom: var(--space-12);
  }

  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: var(--space-8);
    }
  }

  .brand-col img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin-bottom: var(--space-3);
    border: 1px solid var(--color-border);
  }

  .tagline {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    color: var(--color-bone);
    margin-bottom: var(--space-4);
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-bone-dim);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .social:hover { color: var(--color-bone); }
  .social.etsy:hover { border-color: #f1641e; color: #f1641e; }
  .social.fb:hover { border-color: #1877f2; color: #1877f2; }
  .social.email:hover { border-color: var(--color-cyan); color: var(--color-cyan); }

  h4 {
    color: var(--color-coral);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  ul a { color: var(--color-bone-dim); }
  ul a:hover { color: var(--color-bone); }

  .legal {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: var(--space-6);
    color: var(--color-bone-faint);
    font-size: 0.82rem;
  }

  .legal-right a {
    color: var(--color-bone-faint);
  }

  .legal-right a:hover { color: var(--color-bone); }
</style>
