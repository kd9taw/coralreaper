---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="col brand-col">
      <img src="/logo.png" alt="Coral Reaper" width="56" height="56" />
      <p class="tagline">Premium aquacultured corals.</p>
    </div>
    <div class="col">
      <h4>Site</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/drops">Drops</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
    <div class="col">
      <h4>Coming soon</h4>
      <ul>
        <li><span class="muted">Shop · WYSIWYG frags</span></li>
        <li><span class="muted">Live drops · WhatNot</span></li>
        <li><span class="muted">Wholesale</span></li>
      </ul>
    </div>
  </div>
  <hr class="divider" />
  <div class="container legal">
    <span>© {year} Coral Reaper.</span>
    <span class="legal-right">Hand-fragged in the USA.</span>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-24);
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
  }

  .footer-inner {
    display: grid;
    gap: var(--space-12);
    grid-template-columns: 1fr;
    padding-bottom: var(--space-12);
  }

  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: var(--space-8);
    }
  }

  .brand-col img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin-bottom: var(--space-3);
    border: 1px solid var(--color-border);
  }

  .tagline {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    color: var(--color-bone);
  }

  h4 {
    color: var(--color-coral);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  ul a {
    color: var(--color-bone-dim);
  }

  ul a:hover {
    color: var(--color-bone);
  }

  .muted {
    color: var(--color-bone-faint);
  }

  .legal {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-6);
    color: var(--color-bone-faint);
    font-size: 0.82rem;
  }

  .legal-right {
    color: var(--color-bone-faint);
  }
</style>
