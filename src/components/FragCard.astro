---
import type { Frag } from '../data/frags';
import { fragTypeLabels } from '../data/frags';

interface Props {
  frag: Frag;
}

const { frag } = Astro.props;
const priceLabel = frag.price === null ? 'PM for price' : `$${frag.price.toFixed(2)}`;
const statusLabel = frag.status === 'available' ? 'Available' : frag.status === 'reserved' ? 'Reserved' : 'Sold';
---

<a class:list={['card', `status-${frag.status}`]} href={`/frags/${frag.id}`}>
  <div class="image-wrap">
    <img src={frag.image} alt={frag.name} loading="lazy" decoding="async" />
    <span class="type-badge">{fragTypeLabels[frag.type]}</span>
  </div>
  <div class="meta">
    <h3>{frag.name}</h3>
    <div class="row">
      <span class="price">{priceLabel}</span>
      <span class:list={['status', `status-${frag.status}`]}>{statusLabel}</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    color: var(--color-bone);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-coral);
    color: var(--color-bone);
  }

  .image-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    background: #000;
    overflow: hidden;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card:hover img {
    transform: scale(1.04);
  }

  .type-badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: 2px var(--space-2);
    background: rgba(10, 10, 10, 0.78);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-sm);
    color: var(--color-cyan);
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .meta {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin: 0;
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
  }

  .price {
    color: var(--color-bone);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .status {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
  }

  .status.status-available {
    color: var(--color-coral);
    background: rgba(255, 59, 108, 0.1);
  }

  .status.status-reserved {
    color: var(--color-yellow);
    background: rgba(255, 214, 10, 0.1);
  }

  .status.status-sold {
    color: var(--color-bone-faint);
    background: rgba(245, 245, 240, 0.06);
  }

  .card.status-sold img {
    filter: grayscale(0.5) brightness(0.7);
  }
</style>
