---
import EmailSignup from './EmailSignup.astro';
---

<section class="hero">
  <div class="bloom" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="logo-wrap">
      <img src="/logo.png" alt="Coral Reaper logo" width="220" height="220" />
    </div>
    <p class="eyebrow">Premium aquacultured corals</p>
    <h1>The frags worth keeping.</h1>
    <p class="lede">
      Hand-selected, tank-raised corals shipped overnight.
      Limited drops, named pieces, and a list that hears about them first.
    </p>
    <div class="signup-wrap">
      <EmailSignup variant="hero" heading="Get on the list" description="Be first to know when the doors open." />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-24);
    overflow: hidden;
    text-align: center;
    isolation: isolate;
  }

  @media (min-width: 768px) {
    .hero { padding: var(--space-24) 0; }
  }

  .bloom {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 70%;
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 59, 108, 0.18), transparent 55%),
      radial-gradient(circle at 75% 40%, rgba(34, 211, 238, 0.14), transparent 50%),
      radial-gradient(circle at 50% 80%, rgba(255, 214, 10, 0.08), transparent 60%);
    filter: blur(20px);
    z-index: -1;
    pointer-events: none;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .logo-wrap {
    margin-bottom: var(--space-2);
  }

  .logo-wrap img {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    box-shadow:
      0 0 60px rgba(255, 59, 108, 0.15),
      0 0 120px rgba(34, 211, 238, 0.08);
  }

  @media (min-width: 768px) {
    .logo-wrap img { width: 220px; height: 220px; }
  }

  h1 {
    max-width: 18ch;
  }

  .lede {
    color: var(--color-bone-dim);
    font-size: 1.1rem;
    max-width: 52ch;
    margin: 0 auto;
  }

  .signup-wrap {
    width: 100%;
    max-width: 540px;
    margin-top: var(--space-6);
  }
</style>
