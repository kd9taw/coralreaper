---
import { ETSY_SHOP_URL } from '../data/etsy';
import { frags } from '../data/frags';

// Pick the first available frag photo as hero backdrop
const heroFrag = frags.find((f) => f.status === 'available') ?? frags[0];
---

<section class="hero">
  <div class="bg" aria-hidden="true">
    <img src={heroFrag.image} alt="" />
    <div class="bg-overlay"></div>
  </div>

  <div class="container hero-inner">
    <div class="logo-wrap">
      <img src="/logo.png" alt="Coral Reaper logo" width="160" height="160" />
    </div>
    <p class="eyebrow">Frags + custom 3D-printed reef gear</p>
    <h1>Frags I grow.<br /><span class="accent">Gear I print.</span></h1>
    <p class="lede">
      Hand-grown coral frags (local pickup) and custom 3D-printed reef
      accessories (ships nationwide via Etsy). All from one workshop.
    </p>
    <div class="ctas">
      <a class="btn" href="/frags">Browse frags →</a>
      <a class="btn btn-ghost" href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer">
        Shop accessories on Etsy ↗
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-24);
    overflow: hidden;
    text-align: center;
    isolation: isolate;
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero { padding: var(--space-24) 0; }
  }

  .bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px) saturate(1.1) brightness(0.55);
    transform: scale(1.06);
  }

  .bg-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 30%, rgba(10, 10, 10, 0.35), rgba(10, 10, 10, 0.92) 70%),
      linear-gradient(180deg, rgba(10, 10, 10, 0.6) 0%, rgba(10, 10, 10, 0.95) 100%);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
  }

  .logo-wrap img {
    width: 132px;
    height: 132px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    box-shadow:
      0 0 60px rgba(255, 59, 108, 0.18),
      0 0 120px rgba(34, 211, 238, 0.10);
  }

  @media (min-width: 768px) {
    .logo-wrap img { width: 160px; height: 160px; }
  }

  h1 {
    max-width: 18ch;
  }

  .accent { color: var(--color-coral); }

  .lede {
    color: var(--color-bone-dim);
    font-size: 1.1rem;
    max-width: 56ch;
    margin: 0 auto;
  }

  .ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
    align-items: center;
  }

  @media (min-width: 540px) {
    .ctas { flex-direction: row; }
  }
</style>
