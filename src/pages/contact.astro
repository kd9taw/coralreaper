---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FACEBOOK_URL } from '../data/etsy';

// Replace with a real Formspree form ID before going live (see README).
// Until activated, the form will visibly fail; the Facebook + email links
// below provide a working fallback.
const FORMSPREE_ID = 'YOUR_FORM_ID';
const formAction = `https://formspree.io/f/${FORMSPREE_ID}`;
const CONTACT_EMAIL = 'contact@coralreaper.com';

// Honor ?topic=frag&frag=NAME query so a frag detail page can pre-fill.
const topicParam = Astro.url.searchParams.get('topic') ?? '';
const fragParam = Astro.url.searchParams.get('frag') ?? '';
const presetTopic = topicParam === 'frag' ? 'frag' : '';
const presetMessage = fragParam ? `Interested in: ${fragParam}\n\nPickup window: \nNotes: ` : '';
---

<BaseLayout
  title="Contact — Coral Reaper"
  description="Frag inquiries, wholesale, partnerships — get in touch via form, Facebook DM, or email."
>
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Contact</p>
      <h1>Say hi.</h1>
      <p class="lede">
        Frag inquiries (local pickup), wholesale, partnerships, custom 3D-print
        requests, press — all welcome. We aim to reply within a couple of days.
      </p>

      <div class="quick">
        <div>
          <h4>Fastest</h4>
          <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">Facebook DM ↗</a>
        </div>
        <div>
          <h4>Email</h4>
          <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
        </div>
        <div>
          <h4>Or use the form</h4>
          <a href="#contact-form">Below ↓</a>
        </div>
      </div>

      <form class="form" id="contact-form" action={formAction} method="post">
        <div class="row">
          <label>
            <span>Name</span>
            <input name="name" type="text" required autocomplete="name" />
          </label>
          <label>
            <span>Email</span>
            <input name="email" type="email" required autocomplete="email" />
          </label>
        </div>

        <label>
          <span>Topic</span>
          <select name="topic" required>
            <option value="frag" selected={presetTopic === 'frag'}>Frag inquiry — local pickup</option>
            <option value="wholesale">Wholesale</option>
            <option value="custom-print">Custom 3D-print request</option>
            <option value="partnership">Partnership / sponsorship</option>
            <option value="press">Press / media</option>
            <option value="other">Other</option>
          </select>
        </label>

        <label>
          <span>Message</span>
          <textarea
            name="message"
            rows="7"
            required
            placeholder="Which frag(s) or item? Pickup window? Anything else we should know?"
          >{presetMessage}</textarea>
        </label>

        <button type="submit" class="btn">Send</button>
      </form>

      <p class="form-note">
        Form not working? It's on the dev list to wire up next. In the
        meantime <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">message us on Facebook ↗</a>
        or <a href={`mailto:${CONTACT_EMAIL}`}>email {CONTACT_EMAIL}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow { max-width: 720px; }

  .lede {
    font-size: 1.05rem;
    color: var(--color-bone-dim);
    margin-top: var(--space-6);
    margin-bottom: var(--space-12);
    max-width: 56ch;
  }

  .quick {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 640px) {
    .quick { grid-template-columns: repeat(3, 1fr); }
  }

  .quick h4 {
    color: var(--color-coral);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .quick a {
    color: var(--color-bone);
    font-weight: 600;
  }

  .quick a:hover { color: var(--color-coral); }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .row {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .row { grid-template-columns: 1fr 1fr; }
  }

  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-bone-dim);
  }

  input,
  select,
  textarea {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    color: var(--color-bone);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    transition: border-color 0.15s ease;
  }

  textarea {
    resize: vertical;
    min-height: 160px;
    line-height: 1.5;
  }

  textarea::placeholder {
    color: var(--color-bone-faint);
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--color-coral);
    outline: none;
  }

  button { align-self: flex-start; }

  .form-note {
    margin-top: var(--space-8);
    color: var(--color-bone-faint);
    font-size: 0.85rem;
  }
</style>
