---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FACEBOOK_URL } from '../data/etsy';

// Web3Forms access key. Public by design — embedded in the rendered HTML
// for a static client-side POST. Spam protection is via the honeypot
// (botcheck) below + Web3Forms' own server-side filtering.
const WEB3FORMS_ACCESS_KEY = '2010ecc3-3460-4d5e-8650-cfa9eda91980';

const CONTACT_EMAIL = 'contact@coralreaper.com';

// Honor ?topic=frag&frag=NAME query so a frag detail page can pre-fill.
const topicParam = Astro.url.searchParams.get('topic') ?? '';
const fragParam = Astro.url.searchParams.get('frag') ?? '';
const presetTopic = topicParam === 'frag' ? 'frag' : '';
const presetMessage = fragParam ? `Interested in: ${fragParam}\n\nPickup window: \nNotes: ` : '';
---

<BaseLayout
  title="Contact — Coral Reaper"
  description="Frag inquiries, wholesale, partnerships — get in touch via form, Facebook DM, or email."
>
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Contact</p>
      <h1>Say hi.</h1>
      <p class="lede">
        Frag inquiries (local pickup), wholesale, partnerships, custom 3D-print
        requests, press — all welcome. We aim to reply within a couple of days.
      </p>

      <div class="quick">
        <div>
          <h4>Fastest</h4>
          <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">Facebook DM ↗</a>
        </div>
        <div>
          <h4>Email</h4>
          <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
        </div>
        <div>
          <h4>Or use the form</h4>
          <a href="#contact-form">Below ↓</a>
        </div>
      </div>

      <form
        class="form"
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="post"
      >
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="from_name" value="Coral Reaper site" />
        <input
          type="hidden"
          name="subject"
          value="Coral Reaper — new contact form submission"
        />
        <input
          type="checkbox"
          name="botcheck"
          class="hp"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div class="row">
          <label>
            <span>Name</span>
            <input name="name" type="text" required autocomplete="name" />
          </label>
          <label>
            <span>Email</span>
            <input name="email" type="email" required autocomplete="email" />
          </label>
        </div>

        <label>
          <span>Topic</span>
          <select name="topic" required>
            <option value="frag" selected={presetTopic === 'frag'}>Frag inquiry — local pickup</option>
            <option value="wholesale">Wholesale</option>
            <option value="custom-print">Custom 3D-print request</option>
            <option value="partnership">Partnership / sponsorship</option>
            <option value="press">Press / media</option>
            <option value="other">Other</option>
          </select>
        </label>

        <label>
          <span>Message</span>
          <textarea
            name="message"
            rows="7"
            required
            placeholder="Which frag(s) or item? Pickup window? Anything else we should know?"
          >{presetMessage}</textarea>
        </label>

        <button type="submit" class="btn">Send</button>

        <div class="form-status" role="status" aria-live="polite"></div>
      </form>

      <p class="form-note">
        Prefer not to use a form? <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">Message us on Facebook ↗</a>
        or <a href={`mailto:${CONTACT_EMAIL}`}>email {CONTACT_EMAIL}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ FACEBOOK_URL, CONTACT_EMAIL }}>
  const form = document.getElementById('contact-form');
  if (form) {
    const status = form.querySelector('.form-status');
    const submitBtn = form.querySelector('button[type="submit"]');
    const subjectInput = form.querySelector('input[name="subject"]');
    const topicSelect = form.querySelector('select[name="topic"]');

    const topicLabel = (val) => {
      switch (val) {
        case 'frag': return 'Frag inquiry';
        case 'wholesale': return 'Wholesale';
        case 'custom-print': return 'Custom 3D-print request';
        case 'partnership': return 'Partnership / sponsorship';
        case 'press': return 'Press / media';
        default: return 'General';
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.className = 'form-status loading';
      status.textContent = '';
      submitBtn.disabled = true;
      const originalLabel = submitBtn.textContent;
      submitBtn.textContent = 'Sending…';

      // Build a useful subject line from the selected topic + name.
      const fd = new FormData(form);
      const name = (fd.get('name') || '').toString().trim();
      const topic = topicLabel((fd.get('topic') || 'other').toString());
      subjectInput.value = `Coral Reaper — ${topic}${name ? ` from ${name}` : ''}`;
      fd.set('subject', subjectInput.value);

      // Convert FormData to JSON for Web3Forms.
      const payload = {};
      fd.forEach((v, k) => { payload[k] = v; });

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          // Replace the form with a thanks card.
          const thanks = document.createElement('div');
          thanks.className = 'thanks-card';
          thanks.innerHTML = `
            <h3>Got it. We'll be in touch.</h3>
            <p>Reply usually within a couple of days. If it's urgent, message us on
            <a href="${FACEBOOK_URL}" target="_blank" rel="noopener noreferrer">Facebook</a>
            or email <a href="mailto:${CONTACT_EMAIL}">${CONTACT_EMAIL}</a>.</p>
          `;
          form.replaceWith(thanks);
        } else {
          throw new Error(data.message || `HTTP ${res.status}`);
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
        status.className = 'form-status error';
        status.innerHTML =
          `Something went wrong sending the form (${(err && err.message) || 'network error'}). ` +
          `<a href="${FACEBOOK_URL}" target="_blank" rel="noopener noreferrer">Message on Facebook</a> ` +
          `or <a href="mailto:${CONTACT_EMAIL}">email ${CONTACT_EMAIL}</a> instead.`;
      }
    });
  }
</script>

<style>
  .narrow { max-width: 720px; }

  .lede {
    font-size: 1.05rem;
    color: var(--color-bone-dim);
    margin-top: var(--space-6);
    margin-bottom: var(--space-12);
    max-width: 56ch;
  }

  .quick {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 640px) {
    .quick { grid-template-columns: repeat(3, 1fr); }
  }

  .quick h4 {
    color: var(--color-coral);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .quick a {
    color: var(--color-bone);
    font-weight: 600;
  }

  .quick a:hover { color: var(--color-coral); }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .row {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .row { grid-template-columns: 1fr 1fr; }
  }

  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-bone-dim);
  }

  input[type='text'],
  input[type='email'],
  select,
  textarea {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    color: var(--color-bone);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    transition: border-color 0.15s ease;
  }

  textarea {
    resize: vertical;
    min-height: 160px;
    line-height: 1.5;
  }

  textarea::placeholder {
    color: var(--color-bone-faint);
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--color-coral);
    outline: none;
  }

  button { align-self: flex-start; }

  .form-status {
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 0;
    color: var(--color-bone-dim);
    transition: color 0.15s ease;
  }

  .form-status.loading::before {
    content: 'Sending…';
    color: var(--color-bone-dim);
  }

  .form-status.error {
    color: var(--color-coral);
    background: rgba(255, 59, 108, 0.08);
    border: 1px solid rgba(255, 59, 108, 0.3);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
  }

  .form-status.error a {
    color: var(--color-coral);
    text-decoration: underline;
  }

  .thanks-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-yellow);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .thanks-card h3 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    color: var(--color-bone);
    margin: 0;
  }

  .thanks-card p {
    color: var(--color-bone-dim);
    margin: 0;
  }

  .thanks-card a {
    color: var(--color-coral);
    font-weight: 600;
  }

  .form-note {
    margin-top: var(--space-8);
    color: var(--color-bone-faint);
    font-size: 0.85rem;
  }
</style>
