---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { frags, fragTypeLabels, type Frag } from '../../data/frags';
import { FACEBOOK_URL } from '../../data/etsy';

export function getStaticPaths() {
  return frags.map((frag) => ({ params: { id: frag.id }, props: { frag } }));
}

interface Props {
  frag: Frag;
}

const { frag } = Astro.props;
const priceLabel = frag.price === null ? 'PM for price' : `$${frag.price.toFixed(2)}`;
const statusLabel = frag.status === 'available' ? 'Available' : frag.status === 'reserved' ? 'Reserved' : 'Sold';
const typeLabel = fragTypeLabels[frag.type];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: frag.name,
  image: new URL(frag.image, Astro.site).toString(),
  category: typeLabel,
  description: frag.notes || `${typeLabel} frag. Local pickup only.`,
  offers: {
    '@type': 'Offer',
    price: frag.price ?? 0,
    priceCurrency: 'USD',
    availability:
      frag.status === 'available'
        ? 'https://schema.org/InStock'
        : frag.status === 'reserved'
        ? 'https://schema.org/PreOrder'
        : 'https://schema.org/SoldOut',
    url: new URL(`/frags/${frag.id}`, Astro.site).toString(),
    seller: { '@type': 'Organization', name: 'Coral Reaper' },
  },
};

const inquiryHref = `/contact?topic=frag&frag=${encodeURIComponent(frag.name)}`;
---

<BaseLayout
  title={`${frag.name} — Coral Reaper`}
  description={`${typeLabel} frag · ${priceLabel} · ${statusLabel}. Local pickup only.`}
  image={frag.image}
>
  <section class="section detail">
    <div class="container">
      <a href="/frags" class="back">← All frags</a>

      <div class="layout">
        <div class="image-wrap">
          <img src={frag.image} alt={frag.name} />
        </div>

        <div class="info">
          <p class="eyebrow">{typeLabel}</p>
          <h1>{frag.name}</h1>
          <div class="row">
            <span class="price">{priceLabel}</span>
            <span class:list={['status', `status-${frag.status}`]}>{statusLabel}</span>
          </div>
          {frag.notes && <p class="notes">{frag.notes}</p>}

          <div class="pickup-note">
            <strong>Local pickup only.</strong>
            We don't ship live coral yet. Inquire and we'll coordinate a pickup window.
          </div>

          <div class="ctas">
            {frag.status === 'available' ? (
              <>
                <a class="btn" href={inquiryHref}>Inquire about this frag</a>
                <a class="btn btn-ghost" href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">
                  Or message on Facebook ↗
                </a>
              </>
            ) : (
              <span class="unavailable">Not available — check back soon, or browse the rest.</span>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
</BaseLayout>

<style>
  .back {
    display: inline-block;
    color: var(--color-bone-dim);
    font-size: 0.85rem;
    margin-bottom: var(--space-6);
    letter-spacing: 0.04em;
  }

  .back:hover { color: var(--color-coral); }

  .layout {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1fr;
  }

  @media (min-width: 800px) {
    .layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
      align-items: start;
    }
  }

  .image-wrap {
    background: #000;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  h1 {
    margin: 0;
  }

  .row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .price {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-bone);
  }

  .status {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 2px var(--space-3);
    border-radius: var(--radius-sm);
  }

  .status-available {
    color: var(--color-coral);
    background: rgba(255, 59, 108, 0.1);
  }

  .status-reserved {
    color: var(--color-yellow);
    background: rgba(255, 214, 10, 0.1);
  }

  .status-sold {
    color: var(--color-bone-faint);
    background: rgba(245, 245, 240, 0.06);
  }

  .notes {
    color: var(--color-bone-dim);
    margin: 0;
  }

  .pickup-note {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-yellow);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    color: var(--color-bone-dim);
    font-size: 0.9rem;
  }

  .pickup-note strong {
    color: var(--color-yellow);
    margin-right: var(--space-1);
  }

  .ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  @media (min-width: 540px) {
    .ctas { flex-direction: row; flex-wrap: wrap; }
  }

  .unavailable {
    color: var(--color-bone-dim);
    font-size: 0.95rem;
  }
</style>
