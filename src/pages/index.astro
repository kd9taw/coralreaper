---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import DropTeaser from '../components/DropTeaser.astro';
---

<BaseLayout
  title="Coral Reaper — Premium Aquacultured Corals"
  description="Hand-selected, tank-raised corals shipped overnight. Limited weekly drops. Join the list for first access."
>
  <Hero />
  <hr class="divider" />
  <DropTeaser />

  <section class="section how">
    <div class="container">
      <p class="eyebrow">How it works</p>
      <h2>Simple, in three.</h2>
      <ol class="steps">
        <li>
          <span class="num">01</span>
          <h3>Join the list</h3>
          <p>You'll know about every drop, restock, and named release before it goes live.</p>
        </li>
        <li>
          <span class="num">02</span>
          <h3>Pick your frag</h3>
          <p>Every piece photographed under actinic lighting on black. What you see is the exact frag that ships.</p>
        </li>
        <li>
          <span class="num">03</span>
          <h3>Overnight to your door</h3>
          <p>Heat or cold pack as needed. Live arrival guarantee. No cut corners on packaging.</p>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-12);
  }

  @media (min-width: 720px) {
    .steps { grid-template-columns: repeat(3, 1fr); }
  }

  .num {
    display: block;
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--color-coral);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-2);
    line-height: 1;
  }

  .steps h3 {
    margin-bottom: var(--space-2);
  }
</style>
