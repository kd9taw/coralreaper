---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
---

<BaseLayout
  title="Drops — Coral Reaper"
  description="Drop calendar, restocks, and release notes. Join the list to be first."
>
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Drops</p>
      <h1>Coming soon.</h1>
      <p class="lede">
        The first drop is being grown out now. Frags are being cut,
        healed, and photographed. List members get the calendar — and a
        12-hour head start when it goes live.
      </p>

      <div class="status-card">
        <div class="status-row">
          <span class="dot"></span>
          <div>
            <h3>Status</h3>
            <p class="muted">Pre-launch. Building inventory and shooting product photography.</p>
          </div>
        </div>
        <div class="status-row">
          <span class="dot dot-cyan"></span>
          <div>
            <h3>What's first</h3>
            <p class="muted">A small group of aquacultured Acros and a handful of Euphyllia. Numbered, limited, photographed under actinic.</p>
          </div>
        </div>
        <div class="status-row">
          <span class="dot dot-yellow"></span>
          <div>
            <h3>How drops work</h3>
            <p class="muted">Friday evenings. Limited quantities. List members notified 12 hours early. WhatNot live drops will follow.</p>
          </div>
        </div>
      </div>

      <div class="signup-spacer">
        <EmailSignup
          heading="Get the drop calendar"
          description="One email when each drop is scheduled. One email when it's live. Nothing else."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow {
    max-width: 760px;
  }

  .lede {
    font-size: 1.1rem;
    color: var(--color-bone-dim);
    margin-top: var(--space-6);
    max-width: 60ch;
  }

  .status-card {
    margin-top: var(--space-12);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .status-row {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 8px;
    background: var(--color-coral);
    box-shadow: 0 0 12px var(--color-coral);
  }

  .dot-cyan {
    background: var(--color-cyan);
    box-shadow: 0 0 12px var(--color-cyan);
  }

  .dot-yellow {
    background: var(--color-yellow);
    box-shadow: 0 0 12px var(--color-yellow);
  }

  h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-1);
  }

  .muted {
    color: var(--color-bone-dim);
    font-size: 0.98rem;
  }

  .signup-spacer {
    margin-top: var(--space-16);
  }
</style>
