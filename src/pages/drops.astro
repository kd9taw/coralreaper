---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ETSY_SHOP_URL, FACEBOOK_URL } from '../data/etsy';
---

<BaseLayout
  title="Roadmap — Coral Reaper"
  description="What's live now, what's coming next, what's on the horizon for Coral Reaper."
>
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Roadmap</p>
      <h1>What we're building.</h1>
      <p class="lede">
        No "coming soon" theater — just an honest list of what's live now,
        what's next, and what's further out.
      </p>

      <div class="status-card">
        <div class="status-row">
          <span class="dot dot-coral"></span>
          <div>
            <h3>Now · live</h3>
            <ul>
              <li><a href="/frags">Coral frags</a> — local pickup, current grow-out visible on the frags page.</li>
              <li><a href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer">3D-printed reef gear ↗</a> — frag racks, photo boxes, light shades, leg extensions. Ships nationwide via Etsy.</li>
            </ul>
          </div>
        </div>
        <div class="status-row">
          <span class="dot dot-cyan"></span>
          <div>
            <h3>Next · 1–3 months</h3>
            <ul>
              <li>More frag inventory — we're growing out new pieces continuously.</li>
              <li>More gear designs — mounting solutions, dosing accessories, photography helpers.</li>
              <li>Email list — drop alerts and restocks, signup re-enabled when content cadence justifies it.</li>
            </ul>
          </div>
        </div>
        <div class="status-row">
          <span class="dot dot-yellow"></span>
          <div>
            <h3>Later · this year</h3>
            <ul>
              <li>Shipped frags overnight — once we're set up to pack live coral with heat/cold packs and a DOA guarantee.</li>
              <li>Live drops on WhatNot — Friday-night format, list members get a head start.</li>
              <li>Wholesale to local fish stores.</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="cta-row">
        <p>Want updates? Easiest way is <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer">Facebook</a> for now.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow { max-width: 760px; }

  .lede {
    font-size: 1.1rem;
    color: var(--color-bone-dim);
    margin-top: var(--space-6);
    margin-bottom: var(--space-12);
    max-width: 60ch;
  }

  .status-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .status-row {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 8px;
  }

  .dot-coral { background: var(--color-coral); box-shadow: 0 0 12px var(--color-coral); }
  .dot-cyan { background: var(--color-cyan); box-shadow: 0 0 12px var(--color-cyan); }
  .dot-yellow { background: var(--color-yellow); box-shadow: 0 0 12px var(--color-yellow); }

  h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--color-bone-dim);
  }

  ul li::before {
    content: '— ';
    color: var(--color-bone-faint);
  }

  .cta-row {
    margin-top: var(--space-12);
    text-align: center;
    color: var(--color-bone-dim);
  }
</style>
